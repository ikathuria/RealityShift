# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare Worker secrets — set via `wrangler secret put <NAME>` or the
# Cloudflare dashboard. NEVER put these in the frontend or in version control.
# ─────────────────────────────────────────────────────────────────────────────

# Groq API key — console.groq.com (free, no credit card required)
# Runs Llama 4 Maverick for all agent calls. Free tier: 1k req/day, 30 rpm.
GROQ_API_KEY=

# Optional: swap all LLM calls to Claude by setting this + changing LLM_BASE_URL
# in workers/src/ai/llm.ts. Claude Haiku ~$10-30/month for full simulation.
ANTHROPIC_API_KEY=

# Supabase service role key — found in: Project Settings > API > service_role
# Grants full DB access (bypasses RLS). Used only in the Cloudflare Worker.
SUPABASE_SERVICE_KEY=

# NewsAPI.org free account key — newsapi.org/register
# Used for monthly real-world news injection (Milestone 5).
NEWS_API_KEY=

# Secret header value that protects the /api/agents/run and /api/sync/country
# endpoints from unauthorized calls. Set to any long random string.
WORKER_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Frontend environment variables — safe to expose in the browser bundle.
# Create a .env file in the project root with these values for local dev.
# ─────────────────────────────────────────────────────────────────────────────

# Cesium Ion access token — ion.cesium.com (free account)
# Required for terrain, satellite imagery, and higher API quotas.
# The globe renders without it but with reduced quality.
VITE_CESIUM_ION_TOKEN=

# Supabase project URL — found in: Project Settings > API
VITE_SUPABASE_URL=

# Supabase anon key — found in: Project Settings > API > anon (public)
# Safe to expose; RLS policies protect data access.
VITE_SUPABASE_ANON_KEY=

# URL of your deployed Cloudflare Worker
# Local dev: http://localhost:8787
# Production: https://realityshift-api.<your-subdomain>.workers.dev
VITE_AI_PROXY_URL=http://localhost:8787
